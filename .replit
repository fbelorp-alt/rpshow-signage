modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
WHATSAPP_PHONE = "5516982208695"
RESEND_FROM_EMAIL = "contato@rpshow.com.br"

[objectStorage]
defaultBucketID = "replit-objstore-1552befc-a884-49dc-a2b8-4d898b04d755"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 19411
externalPort = 80

[[ports]]
localPort = 20032
externalPort = 3000
